import streamlit as st
import google.generativeai as genai
import json
import re

# --- 1. API & Model Setup ---
api_key = st.secrets.get("GEMINI_API_KEY")
if api_key:
    genai.configure(api_key=api_key)

def get_working_model():
    try:
        models = [m.name for m in genai.list_models() if 'generateContent' in m.supported_generation_methods]
        flash_models = [m for m in models if 'flash' in m]
        return genai.GenerativeModel(flash_models[0] if flash_models else models[0])
    except:
        return genai.GenerativeModel('models/gemini-1.5-flash')

st.set_page_config(page_title="AINet-DB Researcher Pro", layout="wide")

# --- 2. Data Initialization ---
# 起動時に強制的に項目をセットします
if 'data' not in st.session_state:
    st.session_state.data = {
        "aind_id": "AIND-D00000", "original_id": "", 
        "full_name": "", "name_only": "", "full_name_lat": "",
        "activities": [], "teachers": [], "students": [], # ←最初から空リストを確保
        "source_text": "", "translation_jp": "", "translation_en": ""
    }

d = st.session_state.data

# もし古いセッションでstudentsやactivitiesの構造が壊れていたら強制修復
if "students" not in d: d["students"] = []
if "activities" not in d: d["activities"] = []

# --- 3. UI: Main Layout ---
st.title("🌙 AINet-DB Researcher Pro")
col1, col2 = st.columns([1, 1.5])

with col1:
    st.header("1. Source & Analysis")
    source_input = st.text_area("史料テキスト (Arabic)", value=d["source_text"], height=400)
    
    if st.button("🚀 精密解析"):
        if source_input:
            d["source_text"] = source_input
            with st.spinner("解析中..."):
                try:
                    model = get_working_model()
                    prompt = "Extract biographical data into JSON including 'activities' with 'type', and 'students' list."
                    response = model.generate_content(prompt + source_input)
                    json_match = re.search(r"\{.*\}", response.text, re.DOTALL)
                    if json_match:
                        d.update(json.loads(json_match.group()))
                        st.rerun()
                except Exception as e: st.error(f"Error: {e}")

with col2:
    st.header("2. Metadata Editor")
    
    # 1. Activities (ここを完全に固定表示)
    st.subheader("📍 Activities (活動・拠点)")
    st.markdown("地名 / **タイプ(study, buried等)** / ID")
    for i, item in enumerate(d["activities"]):
        # itemが辞書形式でない場合の保護
        if not isinstance(item, dict): d["activities"][i] = {"ar":"","type":"","id":""}
        cols = st.columns([1.2, 1, 1, 0.3])
        item["ar"] = cols[0].text_input("地名", item.get("ar", ""), key=f"a_ar_{i}")
        item["type"] = cols[1].text_input("タイプ", item.get("type", ""), key=f"a_tp_{i}", placeholder="study/buried")
        item["id"] = cols[2].text_input("ID", item.get("id", "TMP-L-00000"), key=f"a_id_{i}")
        if cols[3].button("❌", key=f"a_del_{i}"):
            d["activities"].pop(i)
            st.rerun()
    if st.button("＋ Activity追加"):
        d["activities"].append({"ar":"","type":"","id":"TMP-L-00000"})
        st.rerun()

    st.divider()

    # 2. Teachers
    st.subheader("🎓 Teachers (師匠)")
    for i, item in enumerate(d["teachers"]):
        cols = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = cols[0].text_input("名前", item.get("name", ""), key=f"t_n_{i}")
        item["id"] = cols[1].text_input("ID", item.get("id", "TMP-P-00000"), key=f"t_i_{i}")
        item["subject"] = cols[2].text_input("科目", item.get("subject", ""), key=f"t_s_{i}")
        item["subject_id"] = cols[3].text_input("科目ID", item.get("subject_id", "TMP-W-00000"), key=f"t_si_{i}")
        if cols[4].button("❌", key=f"t_del_{i}"):
            d["teachers"].pop(i)
            st.rerun()
    if st.button("＋ 師匠追加"):
        d["teachers"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"})
        st.rerun()

    st.divider()

    # 3. Students (★Teachersと完全に分離)
    st.subheader("🧑‍🎓 Students (弟子)")
    for i, item in enumerate(d["students"]):
        cols = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = cols[0].text_input("名前", item.get("name", ""), key=f"s_n_{i}")
        item["id"] = cols[1].text_input("ID", item.get("id", "TMP-P-00000"), key=f"s_i_{i}")
        item["subject"] = cols[2].text_input("科目", item.get("subject", ""), key=f"s_s_{i}")
        item["subject_id"] = cols[3].text_input("科目ID", item.get("subject_id", "TMP-W-00000"), key=f"s_si_{i}")
        if cols[4].button("❌", key=f"s_del_{i}"):
            d["students"].pop(i)
            st.rerun()
    if st.button("＋ 弟子追加"):
        d["students"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"})
        st.rerun()

    # --- XML Export ---
    st.divider()
    st.header("3. TEI-XML Export")
    xml = f'<person @xml:id="{d["aind_id"]}">\n'
    for a in d["activities"]:
        xml += f'  <residence @subtype="{a.get("type")}" @ref="{a.get("id")}">{a.get("ar")}</residence>\n'
    xml += '  <listRelation>\n'
    for s in d["students"]:
        xml += f'    <relation @name="student" @active="#{d["aind_id"]}" @passive="#{s.get("id")}"/>\n'
    xml += '  </listRelation>\n</person>'
    st.code(xml, language="xml")
