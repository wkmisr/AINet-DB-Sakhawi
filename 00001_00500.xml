import streamlit as st
import google.generativeai as genai
import json
import re

# --- 1. API & Model Setup ---
api_key = st.secrets.get("GEMINI_API_KEY")
if api_key:
    genai.configure(api_key=api_key)

def get_working_model():
    try:
        models = [m.name for m in genai.list_models() if 'generateContent' in m.supported_generation_methods]
        flash_models = [m for m in models if 'flash' in m]
        return genai.GenerativeModel(flash_models[0] if flash_models else models[0])
    except:
        return genai.GenerativeModel('models/gemini-1.5-flash')

def convert_h_to_g(h_year):
    try:
        h_clean = re.sub(r"\D", "", str(h_year))
        if not h_clean: return ""
        h = int(h_clean)
        return int(h * 0.97 + 622)
    except:
        return ""

st.set_page_config(page_title="AINet-DB Pro Full-XML", layout="wide")

# --- 2. Data State (強制アップデート機能付き) ---
if 'data' not in st.session_state:
    st.session_state.data = {}

# 必要なキーが欠けている場合に強制補完する
default_keys = {
    "aind_id": "AIND-D00000", "original_id": "", "full_name": "", "name_only": "", "full_name_lat": "",
    "birth_h": "", "birth_g": "", "death_h": "", "death_g": "",
    "madhhab": {"lat": "Unknown / Other", "id": ""}, 
    "nisbahs": [], "activities": [], "teachers": [], "students": [], "institutions": [], "family": [], 
    "source_text": "", "translation_jp": "", "translation_en": ""
}

for key, value in default_keys.items():
    if key not in st.session_state.data:
        st.session_state.data[key] = value

d = st.session_state.data

# --- 3. UI: Source Analysis ---
st.title("🌙 AINet-DB Researcher Pro")
col1, col2 = st.columns([1, 1.5])

with col1:
    st.header("1. Source & Analysis")
    source_input = st.text_area("史料テキスト (Arabic)", value=d["source_text"], height=400)
    
    if st.button("🚀 精密解析"):
        if source_input:
            d["source_text"] = source_input
            with st.spinner("解析中..."):
                try:
                    model = get_working_model()
                    prompt = f"""Extract biographical data into JSON.
                    - activities: Extract place AND 'type' (study, buried, etc.).
                    - students: Identify students mentioned.
                    - translation: Provide 'translation_jp' and 'translation_en'.
                    """
                    # プロンプトの詳細は省略するがAIは正しいJSONを返すと想定
                    response = model.generate_content(prompt + source_input)
                    json_match = re.search(r"\{.*\}", response.text, re.DOTALL)
                    if json_match:
                        res_json = json.loads(json_match.group())
                        d.update(res_json)
                        st.rerun()
                except Exception as e: st.error(f"Error: {e}")

# --- 4. UI: Editor ---
with col2:
    st.header("2. Metadata Editor")
    
    # --- Activities セクション (独立して記述) ---
    st.subheader("📍 Activities (活動拠点・埋葬地)")
    st.caption("地名、タイプ(study/buried/reside等)、GeoNames IDを入力")
    for i, item in enumerate(d.get("activities", [])):
        r1, r2, r3, r4 = st.columns([1.2, 1, 1, 0.3])
        item["ar"] = r1.text_input("地名", item.get("ar", ""), key=f"act_ar_fix_{i}")
        item["type"] = r2.text_input("タイプ", item.get("type", ""), key=f"act_tp_fix_{i}", placeholder="study / buried")
        item["id"] = r3.text_input("ID", item.get("id", "TMP-L-00000"), key=f"act_id_fix_{i}")
        if r4.button("❌", key=f"act_del_fix_{i}"): d["activities"].pop(i); st.rerun()
    if st.button("＋ Activity追加"): d["activities"].append({"ar":"","type":"","id":"TMP-L-00000"}); st.rerun()

    # --- Teachers セクション ---
    st.divider()
    st.subheader("🎓 Teachers (師匠)")
    for i, item in enumerate(d.get("teachers", [])):
        r1, r2, r3, r4, r5 = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = r1.text_input("師", item.get("name", ""), key=f"tea_n_fix_{i}")
        item["id"] = r2.text_input("師ID", item.get("id", "TMP-P-00000"), key=f"tea_i_fix_{i}")
        item["subject"] = r3.text_input("内容", item.get("subject", ""), key=f"tea_s_fix_{i}")
        item["subject_id"] = r4.text_input("内容ID", item.get("subject_id", "TMP-W-00000"), key=f"tea_si_fix_{i}")
        if r5.button("❌", key=f"tea_del_fix_{i}"): d["teachers"].pop(i); st.rerun()
    if st.button("＋ 師匠追加"): d["teachers"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"}); st.rerun()

    # --- Students セクション (独立して記述) ---
    st.divider()
    st.subheader("🧑‍🎓 Students (生徒)")
    for i, item in enumerate(d.get("students", [])):
        r1, r2, r3, r4, r5 = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = r1.text_input("弟子", item.get("name", ""), key=f"stu_n_fix_{i}")
        item["id"] = r2.text_input("弟子ID", item.get("id", "TMP-P-00000"), key=f"stu_i_fix_{i}")
        item["subject"] = r3.text_input("内容", item.get("subject", ""), key=f"stu_s_fix_{i}")
        item["subject_id"] = r4.text_input("内容ID", item.get("subject_id", "TMP-W-00000"), key=f"stu_si_fix_{i}")
        if r5.button("❌", key=f"stu_del_fix_{i}"): d["students"].pop(i); st.rerun()
    if st.button("＋ 生徒追加"): d["students"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"}); st.rerun()

    # --- XML Export ---
    st.divider(); st.header("3. TEI-XML Export")
