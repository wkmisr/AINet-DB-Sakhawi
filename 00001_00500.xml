import streamlit as st
import google.generativeai as genai
import json
import re

# --- 設定 ---
st.set_page_config(page_title="AINet-DB Researcher Pro", layout="wide")

# API設定（Secretsまたは直接入力）
api_key = st.secrets.get("GEMINI_API_KEY")
if api_key:
    genai.configure(api_key=api_key)

# --- 1. データの初期化 (キャッシュを完全にリセット) ---
# 起動時に一度だけ、まっさらな状態にします
if 'data_v5' not in st.session_state:
    st.session_state.data_v5 = {
        "aind_id": "AIND-D00000",
        "original_id": "",
        "full_name": "",
        "activities": [{"ar": "", "type": "", "id": ""}], # 項目を1つ用意しておく
        "teachers": [{"name": "", "id": "", "subject": "", "subject_id": ""}],
        "students": [{"name": "", "id": "", "subject": "", "subject_id": ""}], # 強制確保
        "source_text": ""
    }

d = st.session_state.data_v5

# --- 2. レイアウト ---
st.title("🌙 AINet-DB Researcher Pro (Stable v5)")

col1, col2 = st.columns([1, 1.5])

with col1:
    st.header("1. Source Text")
    d["source_text"] = st.text_area("史料テキストを入力", value=d["source_text"], height=300)
    st.info("ここにテキストを貼り付けて、右側のエディタで編集してください。")

with col2:
    st.header("2. Data Editor")
    
    # --- 基本情報 ---
    st.subheader("👤 基本情報")
    d["aind_id"] = st.text_input("Person ID", d["aind_id"])
    d["full_name"] = st.text_input("氏名（アラビア語）", d["full_name"])

    st.divider()

    # --- Activities (タイプ欄を確実に表示) ---
    st.subheader("📍 Activities (活動・拠点)")
    st.caption("地名、活動タイプ(study/buried/reside等)、GeoNames IDを入力")
    new_acts = []
    for i, act in enumerate(d["activities"]):
        c = st.columns([1, 1, 1, 0.3])
        ar = c[0].text_input("地名", act["ar"], key=f"ar_{i}")
        tp = c[1].text_input("タイプ", act["type"], key=f"tp_{i}", placeholder="study, buried...")
        gid = c[2].text_input("ID", act["id"], key=f"id_{i}")
        new_acts.append({"ar": ar, "type": tp, "id": gid})
        if c[3].button("❌", key=f"del_a_{i}"):
            d["activities"].pop(i)
            st.rerun()
    d["activities"] = new_acts
    if st.button("＋ Activityを追加"):
        d["activities"].append({"ar": "", "type": "", "id": ""})
        st.rerun()

    st.divider()

    # --- Teachers ---
    st.subheader("🎓 Teachers (師匠)")
    new_teas = []
    for i, tea in enumerate(d["teachers"]):
        c = st.columns([1, 1, 1, 1, 0.3])
        n = c[0].text_input("名前", tea["name"], key=f"tn_{i}")
        tid = c[1].text_input("ID", tea["id"], key=f"ti_{i}")
        s = c[2].text_input("科目", tea["subject"], key=f"ts_{i}")
        sid = c[3].text_input("科目ID", tea["subject_id"], key=f"tsi_{i}")
        new_teas.append({"name": n, "id": tid, "subject": s, "subject_id": sid})
        if c[4].button("❌", key=f"del_t_{i}"):
            d["teachers"].pop(i)
            st.rerun()
    d["teachers"] = new_teas
    if st.button("＋ 師匠を追加"):
        d["teachers"].append({"name": "", "id": "", "subject": "", "subject_id": ""})
        st.rerun()

    st.divider()

    # --- Students (独立した弟子欄) ---
    st.subheader("🧑‍🎓 Students (弟子)")
    new_stus = []
    for i, stu in enumerate(d["students"]):
        c = st.columns([1, 1, 1, 1, 0.3])
        n = c[0].text_input("名前", stu["name"], key=f"sn_{i}")
        sid = c[1].text_input("ID", stu["id"], key=f"si_{i}")
        s = c[2].text_input("科目", stu["subject"], key=f"ss_{i}")
        ssid = c[3].text_input("科目ID", stu["subject_id"], key=f"ssi_{i}")
        new_stus.append({"name": n, "id": sid, "subject": s, "subject_id": ssid})
        if c[4].button("❌", key=f"del_s_{i}"):
            d["students"].pop(i)
            st.rerun()
    d["students"] = new_stus
    if st.button("＋ 弟子を追加"):
        d["students"].append({"name": "", "id": "", "subject": "", "subject_id": ""})
        st.rerun()

    # --- 3. XML 出力 ---
    st.divider()
    st.header("3. TEI-XML Output")
    
    xml = f'<person @xml:id="{d["aind_id"]}">\n'
    for a in d["activities"]:
        xml += f'  <residence @subtype="{a["type"]}" @ref="{a["id"]}">{a["ar"]}</residence>\n'
    xml += '  <listRelation>\n'
    for t in d["teachers"]:
        xml += f'    <relation @name="teacher" @active="{t["id"]}" @passive="#{d["aind_id"]}"/>\n'
    for s in d["students"]:
        xml += f'    <relation @name="student" @active="#{d["aind_id"]}" @passive="{s["id"]}"/>\n'
    xml += '  </listRelation>\n</person>'
    
    st.code(xml, language="xml")
