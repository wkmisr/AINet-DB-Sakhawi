import streamlit as st
import google.generativeai as genai
import json
import re

# --- 1. API & Model Setup ---
api_key = st.secrets.get("GEMINI_API_KEY")
if api_key:
    genai.configure(api_key=api_key)

def get_working_model():
    try:
        models = [m.name for m in genai.list_models() if 'generateContent' in m.supported_generation_methods]
        flash_models = [m for m in models if 'flash' in m]
        return genai.GenerativeModel(flash_models[0] if flash_models else models[0])
    except:
        return genai.GenerativeModel('models/gemini-1.5-flash')

st.set_page_config(page_title="AINet-DB Researcher Pro", layout="wide")

# --- 2. Data State (強制的リセットロジック) ---
# アプリ起動時、studentsがない場合はsession_stateをクリアして再構築
if 'data' not in st.session_state or 'students' not in st.session_state.data:
    st.session_state.data = {
        "aind_id": "AIND-D00000", "original_id": "", 
        "full_name": "", "name_only": "", "full_name_lat": "",
        "birth_h": "", "birth_g": "", "death_h": "", "death_g": "",
        "madhhab": {"lat": "Unknown / Other", "id": ""}, 
        "nisbahs": [], 
        "activities": [], # typeが含まれるようになる
        "teachers": [], 
        "students": [],  # これが確実に作成される
        "institutions": [], "family": [], 
        "source_text": "", "translation_jp": "", "translation_en": ""
    }

d = st.session_state.data

# --- 3. UI: Source Analysis ---
st.title("🌙 AINet-DB Researcher Pro")
col1, col2 = st.columns([1, 1.5])

with col1:
    st.header("1. Source & Analysis")
    source_input = st.text_area("史料テキスト (Arabic)", value=d["source_text"], height=400)
    
    if st.button("🚀 精密解析"):
        if source_input:
            d["source_text"] = source_input
            with st.spinner("AI解析中..."):
                try:
                    model = get_working_model()
                    prompt = f"""Extract data into JSON. 
                    - activities: include 'type' (study, buried, visit, reside).
                    - students: list students with name, id, subject, subject_id.
                    JSON: {{ "full_name":"", "name_only":"", "activities":[{"ar":"", "type":"", "id":""}], "students":[{"name":"","id":"","subject":"","subject_id":""}], ... }}
                    Text: {source_input}"""
                    response = model.generate_content(prompt)
                    json_match = re.search(r"\{.*\}", response.text, re.DOTALL)
                    if json_match:
                        d.update(json.loads(json_match.group()))
                        st.rerun()
                except Exception as e: st.error(f"Error: {e}")

# --- 4. UI: Editor ---
with col2:
    st.header("2. Metadata Editor")

    # --- Activities ---
    st.subheader("📍 Activities (活動・拠点)")
    for i, item in enumerate(d.get("activities", [])):
        r = st.columns([1, 1, 1, 0.3])
        item["ar"] = r[0].text_input("地名", item.get("ar", ""), key=f"a_ar_v3_{i}")
        item["type"] = r[1].text_input("タイプ", item.get("type", ""), key=f"a_tp_v3_{i}", placeholder="buried / study")
        item["id"] = r[2].text_input("ID", item.get("id", "TMP-L-00000"), key=f"a_id_v3_{i}")
        if r[3].button("❌", key=f"a_del_v3_{i}"): d["activities"].pop(i); st.rerun()
    if st.button("＋ Activity追加"): d["activities"].append({"ar":"","type":"","id":"TMP-L-00000"}); st.rerun()

    # --- Teachers ---
    st.divider()
    st.subheader("🎓 Teachers (師匠)")
    for i, item in enumerate(d.get("teachers", [])):
        r = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = r[0].text_input("師匠名", item.get("name", ""), key=f"t_n_v3_{i}")
        item["id"] = r[1].text_input("師ID", item.get("id", "TMP-P-00000"), key=f"t_i_v3_{i}")
        item["subject"] = r[2].text_input("内容", item.get("subject", ""), key=f"t_s_v3_{i}")
        item["subject_id"] = r[3].text_input("内容ID", item.get("subject_id", "TMP-W-00000"), key=f"t_si_v3_{i}")
        if r[4].button("❌", key=f"t_del_v3_{i}"): d["teachers"].pop(i); st.rerun()
    if st.button("＋ 師匠追加"): d["teachers"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"}); st.rerun()

    # --- Students (独立セクション) ---
    st.divider()
    st.subheader("🧑‍🎓 Students (生徒/弟子)")
    for i, item in enumerate(d.get("students", [])):
        r = st.columns([1, 1, 1, 1, 0.3])
        item["name"] = r[0].text_input("弟子名", item.get("name", ""), key=f"s_n_v3_{i}")
        item["id"] = r[1].text_input("弟子ID", item.get("id", "TMP-P-00000"), key=f"s_i_v3_{i}")
        item["subject"] = r[2].text_input("内容", item.get("subject", ""), key=f"s_s_v3_{i}")
        item["subject_id"] = r[3].text_input("内容ID", item.get("subject_id", "TMP-W-00000"), key=f"s_si_v3_{i}")
        if r[4].button("❌", key=f"s_del_v3_{i}"): d["students"].pop(i); st.rerun()
    if st.button("＋ 弟子追加"): d["students"].append({"name":"","id":"TMP-P-00000","subject":"","subject_id":"TMP-W-00000"}); st.rerun()

    # --- 5. XML Export ---
    st.divider()
    st.header("3. TEI-XML Export")
    
    xml = f'<person @xml:id="{d["aind_id"]}">\n'
    for s in d.get("students", []):
        xml += f'    <relation @name="student" @active="#{d["aind_id"]}" @passive="#{s.get("id")}"/>\n'
    xml += '</person>'
    st.code(xml, language="xml")
